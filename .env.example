# Only Development
NODE_ENV=development

# Application
NEXT_PUBLIC_APP_NAME="Settlr"
NEXT_PUBLIC_APP_DESCRIPTION="Settlr for managing personal finance"

# Better Auth
# Generate random auth secret from
# https://www.better-auth.com/docs/installation#set-environment-variables
BETTER_AUTH_SECRET=lMD1eol2MrTxIZixGYyjwT0G0DQJ6oLJ
BETTER_AUTH_URL=http://localhost:3000
# Replace with actual origin insted of example
BETTER_AUTH_TRUSTED_ORIGINS=https://example.com,https://*.example.com

# DATABASE
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=settlr
POSTGRES_PORT=5432
POSTGRES_EXTERNAL_PORT=5433
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# Email Service
SMTP_HOST=<mail.example.com>
SMTP_PORT=587                               # or 465 for SSL
SMTP_USER=<USER@example.com>
SMTP_PASS=<USER_PASSWORD>
SMTP_SECURE=false                           # false for STARTTLS (587), true for SSL (465)
FROM_EMAIL=<app@example.com>

# Google login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=