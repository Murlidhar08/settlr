{
  "name": "next-template",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --webpack",
    "start": "node server.js",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "production-deploy": "npm run postinstall && prisma migrate deploy && npm run build",
    "production-build": "npm run postinstall && npm run build",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "db:deploy": "npx prisma migrate deploy && npx prisma generate",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "auth:generate": "npx @better-auth/cli@latest generate --config ./lib/auth/auth.ts --yes",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pg": "^8.20.0",
    "@base-ui/react": "^1.4.1",
    "@better-auth/passkey": "^1.6.9",
    "@better-auth/prisma-adapter": "^1.6.9",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.100.8",
    "@tanstack/react-query-devtools": "^5.100.8",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.14.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "nodemailer": "^8.0.7",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.75.0",
    "react-qr-code": "^2.0.21",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@next/bundle-analyzer": "^16.2.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.4",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}