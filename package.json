{
  "name": "next-template",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --webpack",
    "start": "node server.js",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "production-deploy": "npm run postinstall && prisma migrate deploy && npm run build",
    "production-build": "npm run postinstall && npm run build",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "db:deploy": "npx prisma migrate deploy && npx prisma generate",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "auth:generate": "npx @better-auth/cli@latest generate --config ./lib/auth/auth.ts --yes",
    "typecheck": "tsc --noEmit",
    "sync-template": "git fetch upstream && git merge upstream/main"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@better-auth/passkey": "^1.6.11",
    "@better-auth/prisma-adapter": "^1.6.11",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@types/pg": "^8.20.0",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "nodemailer": "^8.0.9",
    "prisma": "^7.8.0",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "react-qr-code": "^2.0.21",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@next/bundle-analyzer": "^16.2.6",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.0",
    "eslint-config-next": "^16.2.6",
    "jimp": "^1.6.1",
    "pg": "^8.21.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
